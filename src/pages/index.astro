---
import BaseLayout from '../layouts/BaseLayout.astro'
import TraceStack from '../components/TraceStack.astro'
import {
  actionTasks,
  evidenceItems,
  priorityLabels,
  researchReferenceById,
  scenarios,
  sources,
} from '../data/content'
import { groupTasks, statusCounts } from '../lib/guide'

const taskGroups = groupTasks(actionTasks)
const evidenceCounts = statusCounts(evidenceItems.map(({ status }) => status))
const description =
  '給獨立記者與敏感議題寫作者的 Matters 安全指南。從查資料、聯絡、上稿與收款，一路看懂平台來函、洋蔥小站、IPFS 與個人備份。'

const requestSteps = [
  {
    index: '01',
    title: '確認來文機關與調閱範圍',
    body: '來文機關、法律依據、帳號、資料種類與時間範圍都要寫清楚。要求太廣或說不明白，不能直接往下查。',
  },
  {
    index: '02',
    title: '由法律顧問檢查管轄與必要性',
    body: '平台主體、後台所在地、案件性質與使用者所在國家都會影響判斷。兒少安全與一般刑事調查也不能混成同一套處理。',
  },
  {
    index: '03',
    title: '盤點平台現有資料',
    body: '公文寄到之後，資料不會憑空出現。平台平常少收一項、少留一天，遇到調閱時就少一項可以交出去。',
  },
  {
    index: '04',
    title: '記錄回覆內容與處理理由',
    body: '有資料、沒有資料、拒絕提供或立即處理，都應留下範圍與理由，之後才有辦法做透明度報告與外部檢查。',
  },
]

const governmentCases = [
  {
    date: '2023.02',
    agency: '法務部調查局',
    request: '查詢帳號註冊資料與綁定錢包',
    result: '治理紀錄寫明，平台僅能確認沒有綁定錢包，其餘資料已無法回復。',
  },
  {
    date: '2023.05',
    agency: '台中警察局',
    request: '要求提供使用者 IP 位址',
    result: '治理紀錄寫明，公函半年後才收到，平台未回覆。',
  },
  {
    date: '2025.07',
    agency: '台北警察局',
    request: '妨害名譽案要求 IP 等資料',
    result: '治理紀錄記為未回覆，沒有公開更多個案細節。',
  },
]
---

<BaseLayout title="Matters 安全指南｜獨立記者的數位足跡與安全準備" description={description}>
  <header class="site-header" data-site-header>
    <a class="wordmark" href="#top" aria-label="Matters 安全指南首頁">
      <img class="wordmark__graph" src="/brand/matters-logo-graph.svg" alt="" />
      <img class="wordmark__logo" src="/brand/matters-logo.svg" alt="Matters" />
      <span class="wordmark__divider" aria-hidden="true"></span>
      <span>安全指南</span>
    </a>
    <nav class="site-nav" aria-label="主要導覽">
      <a href="#trace">採訪路線</a>
      <a href="#platform-requests">平台來函</a>
      <a href="#plan">行動清單</a>
      <a href="#evidence">平台措施</a>
    </nav>
    <div class="mobile-header-actions">
      <a class="mobile-emergency-link" href="#emergency">出事怎麼辦</a>
      <details class="mobile-menu" data-mobile-menu>
        <summary>目錄</summary>
        <nav aria-label="行動版主要導覽">
          <a href="#trace">採訪路線</a>
          <a href="#platform-requests">平台來函</a>
          <a href="#plan">行動清單</a>
          <a href="#evidence">平台措施</a>
          <a href="#emergency">出事怎麼辦</a>
          <a href="#sources">研究來源</a>
        </nav>
      </details>
    </div>
    <a class="header-meta" href="#about">2026.07<br />第二版</a>
  </header>

  <main id="main-content">
    <section class="hero" id="top" aria-labelledby="hero-title">
      <div class="hero__copy">
        <p class="eyebrow" data-hero-item>MATTERS FIELD GUIDE · FOR INDEPENDENT JOURNALISTS</p>
        <h1 id="hero-title">
          獨立記者的<br /><span>數位足跡</span>
        </h1>
        <p class="hero__lead" data-hero-item>
          用化名發稿，只處理了名字。登入的信箱、裝置、連線方式、照片中繼資料與收款紀錄，仍可能把零散片段接回你身上。這份指南陪你走一遍從查資料到發稿後的路。
        </p>
        <div class="hero__actions" data-hero-item>
          <a class="ds-btn ds-btn--primary ds-btn--large" href="#trace">從採訪流程開始</a>
          <a class="text-link" href="#evidence">Matters 做了什麼 <span aria-hidden="true">↘</span></a>
        </div>
      </div>
      <div class="hero__visual" data-hero-map>
        <TraceStack context="hero" />
        <p class="hero__caption"><span>FIG. 01</span> 每個服務只看到一部分，拼在一起才會接近完整輪廓</p>
      </div>
    </section>

    <aside class="emergency-rail" aria-label="急迫事件快速入口">
      <p><span class="signal-dot"></span>現在就有狀況嗎</p>
      <a href="#account-compromise">帳號進不去或資料被改</a>
      <a href="#harassment">有人持續威脅或追蹤</a>
      <a href="#device-monitoring">懷疑裝置被監控</a>
      <a class="emergency-rail__help" href="https://www.accessnow.org/help/" target="_blank" rel="noopener noreferrer">找外部專業支援 ↗</a>
    </aside>

    <section class="principles section-shell" id="principles" aria-labelledby="principles-title">
      <header class="section-heading">
        <p class="eyebrow">BEFORE YOU START</p>
        <h2 id="principles-title">使用化名前的三項提醒</h2>
        <p>工具能幫你少留一些線索，實際保護到哪裡，仍要看對手、工作內容與你願意付出的操作成本。</p>
      </header>
      <div class="principle-list">
        <article>
          <p class="principle-list__index">01</p>
          <h3>換了名字，其他身分線索還在</h3>
          <p>名稱換掉之後，信箱、頭像、活動時間、寫作習慣與收款方式還在。只要其中幾項被重複使用，身分就有機會被接起來。</p>
        </article>
        <article>
          <p class="principle-list__index">02</p>
          <h3>不同服務會留下不同紀錄</h3>
          <p>瀏覽器、網路服務商、平台、支付商與公開鏈看到的內容不同。先畫出資料經過誰，再決定哪一段需要換工具。</p>
        </article>
        <article>
          <p class="principle-list__index">03</p>
          <h3>公開內容往往無法全數收回</h3>
          <p>搜尋引擎、讀者備份、截圖與 IPFS 都可能留下副本。抗刪除對新聞保存很重要，對更正、撤回與來源保護也會帶來代價。</p>
        </article>
      </div>
    </section>

    <section class="trace-story" id="trace" aria-labelledby="trace-title" data-trace-story>
      <header class="section-heading section-shell">
        <p class="eyebrow">ACTIVE TRACE</p>
        <h2 id="trace-title">採訪、發稿與收款留下的紀錄</h2>
        <p>往下看四段工作情境。右邊的資料層會跟著切換，讓你看見同一個動作可能同時落在哪幾個地方。</p>
      </header>

      <div class="trace-layout section-shell">
        <div class="trace-chapters">
          {scenarios.map((scenario, index) => (
            <article
              class:list={['trace-chapter', { 'is-active': index === 0 }]}
              data-trace-chapter={scenario.id}
              aria-current={index === 0 ? 'step' : undefined}
            >
              <p class="trace-chapter__index">{scenario.index} / 04</p>
              <p class="trace-chapter__kicker">{scenario.kicker}</p>
              <h3>{scenario.title}</h3>
              <p class="trace-chapter__summary">{scenario.summary}</p>
              <div class="trace-chapter__lists">
                <div>
                  <h4>可能留下什麼</h4>
                  <ul>{scenario.traces.map((trace) => <li>{trace}</li>)}</ul>
                </div>
                <div>
                  <h4>現在可以怎麼做</h4>
                  <ul>{scenario.actions.map((action) => <li>{action}</li>)}</ul>
                </div>
              </div>
            </article>
          ))}
        </div>
        <div class="trace-visual-wrap" data-trace-pin>
          <TraceStack context="story" />
        </div>
      </div>
    </section>

    <section class="platform-requests" id="platform-requests" aria-labelledby="platform-requests-title">
      <div class="section-shell">
        <header class="section-heading section-heading--split">
          <div>
            <p class="eyebrow">FROM THE PLATFORM SIDE</p>
            <h2 id="platform-requests-title">政府資料調閱公文的<br />平台處理流程</h2>
          </div>
          <p>來函只是一個起點。平台平常收了多少、留了多久，才決定手上有多少資料能被調閱。</p>
        </header>

        <div class="platform-requests__layout">
          <figure class="platform-requests__figure">
            <img src="/illustrations/platform-request.jpg" alt="Matters 角色站在天平旁，衡量平台治理、法律要求與使用者權益" loading="lazy" width="1536" height="1024" />
            <figcaption>
              <span>FROM 看不見的平台清道夫</span>
              同一套視覺裡，平台需要同時面對內容治理、公權力與使用者安全。
            </figcaption>
          </figure>

          <ol class="request-flow">
            {requestSteps.map((step) => (
              <li>
                <span>{step.index}</span>
                <div><h3>{step.title}</h3><p>{step.body}</p></div>
              </li>
            ))}
          </ol>
        </div>

        <div class="case-file">
          <div class="case-file__intro">
            <p class="eyebrow">CASE FILE · SELF-REPORTED</p>
            <h3>三次政府調閱資料紀錄</h3>
            <p>以下是 Matters 公開治理資料整理出的歷史紀錄。它們能說明過去發生過什麼，不能當成法律意見，也不能保證未來每一案都會用相同方式處理。</p>
            <a href="https://thematters.github.io/matters-governance-site/reading/platform-meets-law/" target="_blank" rel="noopener noreferrer">查看〈平台遇上法律〉全文 ↗</a>
          </div>
          <div class="case-file__list">
            {governmentCases.map((item) => (
              <article>
                <p><span>{item.date}</span>{item.agency}</p>
                <h4>{item.request}</h4>
                <p>{item.result}</p>
              </article>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="action-plan section-shell" id="plan" aria-labelledby="plan-title" data-action-plan>
      <header class="section-heading section-heading--split">
        <div>
          <p class="eyebrow">YOUR FIELD NOTES</p>
          <h2 id="plan-title">依採訪情境<br />整理安全清單</h2>
        </div>
        <p>清單只在目前頁面運作，不會保存或送出。你可以複選工作情境，再把結果複製或列印下來。</p>
      </header>

      <div class="scenario-picker" aria-labelledby="scenario-picker-title">
        <div>
          <p class="scenario-picker__label" id="scenario-picker-title">我會在 Matters 做這些事</p>
          <p class="scenario-picker__hint">可以複選。沒有選擇時會顯示完整清單。</p>
        </div>
        <div class="scenario-picker__buttons" role="group" aria-label="選擇使用情境">
          {scenarios.map((scenario) => (
            <button class="scenario-button" type="button" data-scenario-button={scenario.id} aria-pressed="false">
              <span>{scenario.index}</span>{scenario.title}
            </button>
          ))}
        </div>
      </div>

      <div class="plan-status" aria-live="polite">
        <p data-plan-summary>目前顯示完整清單，共 {actionTasks.length} 項</p>
        <div class="plan-tools" aria-label="清單工具">
          <button type="button" class="plan-reset" data-plan-reset>清除選擇與勾選</button>
          <button type="button" class="ds-btn ds-btn--secondary ds-btn--medium" data-plan-copy>複製清單</button>
          <button type="button" class="ds-btn ds-btn--secondary ds-btn--medium" data-plan-print>列印</button>
        </div>
      </div>

      <div class="task-columns">
        {Object.entries(priorityLabels).map(([priority, label]) => (
          <section class={`task-column task-column--${priority}`} data-task-group={priority}>
            <header>
              <span>{label.index}</span>
              <div><h3>{label.title}</h3><p>{label.note}</p></div>
            </header>
            <div class="task-list">
              {taskGroups[priority as keyof typeof taskGroups].map((task) => (
                <article class="task-card" data-task-card data-task-id={task.id} data-scenarios={task.scenarios.join(',')}>
                  <label class="task-card__toggle">
                    <input type="checkbox" data-task-checkbox />
                    <span class="task-card__check" aria-hidden="true"></span>
                    <span class="task-card__body"><strong>{task.title}</strong><span>{task.detail}</span></span>
                  </label>
                  <small class="task-card__sources">
                    參考{' '}
                    {task.sourceIds.map((sourceId, sourceIndex) => {
                      const source = researchReferenceById.get(sourceId)
                      if (!source) return null
                      return <>{sourceIndex > 0 && '、'}<a href={source.href} target="_blank" rel="noopener noreferrer">{source.shortName}</a></>
                    })}
                  </small>
                </article>
              ))}
            </div>
          </section>
        ))}
      </div>
    </section>

    <section class="evidence section-shell" id="evidence" aria-labelledby="evidence-title" data-dashboard>
      <header class="section-heading section-heading--split">
        <div>
          <p class="eyebrow">WHAT MATTERS DOES</p>
          <h2 id="evidence-title">Matters 目前提供的隱私與備份措施</h2>
        </div>
        <p>每一項都同時寫出證據與保護不到的地方。查不到的部分會留在「待補證據」，不拿推測補空白。</p>
      </header>

      <div class="measure-strip" aria-label="Matters 抗審查與備份工具">
        <a href="https://github.com/thematters/matters-onion-gateway" target="_blank" rel="noopener noreferrer">
          <span>READ</span><h3>洋蔥小站</h3><p>不想直接連上公開網站時，可從 Tor 走唯讀入口。目前不能登入或發稿。</p><i>01 ↗</i>
        </a>
        <a href="https://thematters.github.io/matters-governance-site/reading/hack-the-platform/" target="_blank" rel="noopener noreferrer">
          <span>KEEP</span><h3>IPFS 發布</h3><p>公開文章發布後會觸發 IPFS 流程，讓內容有機會從站外依 CID 取回。</p><i>02 ↗</i>
        </a>
        <a href="https://lifeboat.matters.town/" target="_blank" rel="noopener noreferrer">
          <span>OWN</span><h3>記憶吐司</h3><p>把公開文章下載成自己的備份，或放進自己的保存空間與部落格。</p><i>03 ↗</i>
        </a>
      </div>

      <div class="dashboard-summary" aria-label="證據狀態總覽">
        <article>
          <p><span class="status-shape status-shape--verified"></span>已驗證</p>
          <strong><span class="sr-only">{evidenceCounts.verified} 項</span><span aria-hidden="true" data-count={evidenceCounts.verified}>{evidenceCounts.verified}</span></strong>
          <span>項有公開或可重現的證據</span>
        </article>
        <article>
          <p><span class="status-shape status-shape--pending"></span>待補證據</p>
          <strong><span class="sr-only">{evidenceCounts.pending} 項</span><span aria-hidden="true" data-count={evidenceCounts.pending}>{evidenceCounts.pending}</span></strong>
          <span>項還需要產品或治理團隊補資料</span>
        </article>
        <article>
          <p><span class="status-shape status-shape--policy"></span>政策處理中</p>
          <strong><span class="sr-only">{evidenceCounts.policy} 項</span><span aria-hidden="true" data-count={evidenceCounts.policy}>{evidenceCounts.policy}</span></strong>
          <span>項等待條款與 NCC 批次更新</span>
        </article>
        <div class="dashboard-bar" aria-hidden="true">
          {Array.from({ length: evidenceCounts.verified }).map(() => <span class="dashboard-bar__verified"></span>)}
          {Array.from({ length: evidenceCounts.pending }).map(() => <span class="dashboard-bar__pending"></span>)}
          {Array.from({ length: evidenceCounts.policy }).map(() => <span class="dashboard-bar__policy"></span>)}
        </div>
      </div>

      <div class="evidence-list">
        {evidenceItems.map((item, index) => (
          <article class="evidence-card" data-evidence-card>
            <p class="evidence-card__index">{String(index + 1).padStart(2, '0')}</p>
            <div class="evidence-card__main">
              <div class="evidence-card__title">
                <h3>{item.title}</h3>
                <span class={`status-badge status-badge--${item.status}`}><i class={`status-shape status-shape--${item.status}`}></i>{item.statusLabel}</span>
              </div>
              <dl>
                <div><dt>目前查到的證據</dt><dd>{item.evidence}</dd></div>
                <div><dt>保護不到的地方</dt><dd>{item.limit}</dd></div>
                <div><dt>最後驗證</dt><dd>{item.verifiedAt}</dd></div>
                <div><dt>負責方</dt><dd>{item.owner}</dd></div>
              </dl>
            </div>
            <a class="evidence-card__link" href={item.href} target="_blank" rel="noopener noreferrer" aria-label={`查看 ${item.title} 的證據`}>↗</a>
          </article>
        ))}
      </div>
      <p class="evidence-note">完整維護規則與 repo 證據收在 <a href="https://github.com/thematters/matters-safety-guide/blob/main/docs/evidence-matrix.md" target="_blank" rel="noopener noreferrer">evidence matrix ↗</a></p>
    </section>

    <section class="incident section-shell" id="emergency" aria-labelledby="incident-title">
      <header class="section-heading">
        <p class="eyebrow">WHEN SOMETHING HAPPENS</p>
        <h2 id="incident-title">帳號、騷擾與裝置事件的處理順序</h2>
        <p>若有人身危險，先離開現場並聯絡可信任的人。不要為了查清楚數位問題，讓自己留在更危險的位置。</p>
      </header>
      <div class="incident-list">
        <details id="account-compromise" open>
          <summary><span>01</span>帳號進不去，或資料被改了</summary>
          <div><ol>
            <li>換到可信任、乾淨的裝置，再開註冊信箱與 Matters。</li>
            <li>先改信箱密碼，再處理平台密碼與仍在登入的裝置。</li>
            <li>留下異常通知、時間與變更紀錄，截圖不要包含更多敏感資料。</li>
            <li>看不出入侵範圍時，先停下來，改找專業支援。</li>
          </ol></div>
        </details>
        <details id="harassment">
          <summary><span>02</span>有人持續騷擾、威脅或追蹤</summary>
          <div><ol>
            <li>保留原始網址、時間與必要截圖，別為了蒐證反覆轉貼威脅內容。</li>
            <li>回頭檢查舊文章、個人頁與其他平台，看看能不能拼出住處、工作或關係人。</li>
            <li>告訴可信任的人，約好固定的報平安時間與失聯處理方式。</li>
            <li>對方提到現實位置或暴力時，立刻找在地法律與人身安全支援。</li>
          </ol></div>
        </details>
        <details id="device-monitoring">
          <summary><span>03</span>懷疑手機或電腦被監控</summary>
          <div><ol>
            <li>先別用原裝置搜尋移除方式、改密碼或討論事件。</li>
            <li>換一部可信任裝置與網路，聯絡有數位鑑識經驗的支援者。</li>
            <li>不要急著重置或刪資料，以免破壞證據，或讓對方發現你已經察覺。</li>
            <li>讓專業人員一起排帳號、裝置與人身風險的處理順序。</li>
          </ol></div>
        </details>
      </div>
      <div class="incident-help">
        <div>
          <p>一般帳號與平台問題可先找 Matters。涉及監控、跨境追查或人身風險時，直接聯絡外部數位安全支援。</p>
          <a href="mailto:ask@matters.town">ask@matters.town</a>
        </div>
        <a class="ds-btn ds-btn--primary ds-btn--large" href="https://www.accessnow.org/help/" target="_blank" rel="noopener noreferrer">Access Now 24/7 數位安全熱線 ↗</a>
      </div>
    </section>

    <section class="sources section-shell" id="sources" aria-labelledby="sources-title">
      <header class="section-heading section-heading--split">
