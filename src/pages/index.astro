---
import BaseLayout from '../layouts/BaseLayout.astro'
import FootprintMap from '../components/FootprintMap.astro'
import {
  actionTasks,
  evidenceItems,
  knowledgeTopics,
  priorityLabels,
  researchReferenceById,
  scenarios,
  sources,
} from '../data/content'
import { groupTasks, statusCounts } from '../lib/guide'

const taskGroups = groupTasks(actionTasks)
const evidenceCounts = statusCounts(evidenceItems.map(({ status }) => status))
const description =
  '從閱讀、互動、發布到金流，理解數位足跡，建立自己的安全行動清單，並查核 Matters 已有與待補的保護措施。'
---

<BaseLayout title="Matters 安全指南｜先看見足跡，再決定怎麼行動" description={description}>
  <header class="site-header" data-site-header>
    <a class="wordmark" href="#top">
      <span class="wordmark__mark" aria-hidden="true">M</span>
      <span class="sr-only">Matters</span>
      <span>安全指南</span>
    </a>
    <nav class="site-nav" aria-label="主要導覽">
      <a href="#trace">數位足跡</a>
      <a href="#plan">行動清單</a>
      <a href="#evidence">平台措施</a>
      <a href="#emergency">急迫事件</a>
    </nav>
    <div class="mobile-header-actions">
      <a class="mobile-emergency-link" href="#emergency">急迫事件</a>
      <details class="mobile-menu" data-mobile-menu>
        <summary>目錄</summary>
        <nav aria-label="行動版主要導覽">
          <a href="#trace">數位足跡</a>
          <a href="#plan">行動清單</a>
          <a href="#evidence">平台措施</a>
          <a href="#emergency">急迫事件</a>
          <a href="#sources">研究來源</a>
        </nav>
      </details>
    </div>
    <a class="header-meta" href="#about">2026.07<br />第一版</a>
  </header>

  <main id="main-content">
    <section class="hero" id="top" aria-labelledby="hero-title">
      <div class="hero__copy">
        <p class="eyebrow" data-hero-item>MATTERS FIELD GUIDE · 001</p>
        <h1 id="hero-title">
          先看見<br />足跡，<br /><span>再決定怎麼行動</span>
        </h1>
        <p class="hero__lead" data-hero-item>
          化名能降低部分曝險，不能抹去裝置、網路、互動與金流留下的線索。從你的使用情境出發，建立一套不誇大承諾的保護方式。
        </p>
        <div class="hero__actions" data-hero-item>
          <a class="ds-btn ds-btn--primary ds-btn--large" href="#trace">開始辨識足跡</a>
          <a class="text-link" href="#principles">先讀三個界線 <span aria-hidden="true">↘</span></a>
        </div>
      </div>
      <div class="hero__visual" data-hero-map>
        <FootprintMap context="hero" />
        <p class="hero__caption"><span>FIG. 01</span> 線索常在不同服務之間被重新拼接</p>
      </div>
    </section>

    <aside class="emergency-rail" aria-label="急迫事件快速入口">
      <p><span class="signal-dot"></span>現在有急迫風險嗎</p>
      <a href="#account-compromise">帳號疑似遭入侵</a>
      <a href="#harassment">持續騷擾或威脅</a>
      <a href="#device-monitoring">裝置疑似被監控</a>
      <a class="emergency-rail__help" href="https://www.accessnow.org/help/" target="_blank" rel="noopener noreferrer">尋求外部協助 ↗</a>
    </aside>

    <section class="principles section-shell" id="principles" aria-labelledby="principles-title">
      <header class="section-heading">
        <p class="eyebrow">READ THIS FIRST</p>
        <h2 id="principles-title">先記住三個界線</h2>
        <p>安全不是一次設定完成的狀態。你面對的對手、可接受的代價與使用方式改變，做法也要跟著調整。</p>
      </header>
      <div class="principle-list">
        <article>
          <p class="principle-list__index">01</p>
          <h3>隱私不等於匿名</h3>
          <p>隱私是控制誰能看見哪些資訊。匿名則要求不同線索難以連回同一個人，門檻更高，也更依賴操作習慣。</p>
        </article>
        <article>
          <p class="principle-list__index">02</p>
          <h3>化名不等於冒充</h3>
          <p>分開化名與日常身分可以減少關聯，但不能使用他人身分，也不會消除付款、裝置或關係網留下的足跡。</p>
        </article>
        <article>
          <p class="principle-list__index">03</p>
          <h3>可保存不等於可撤回</h3>
          <p>公開內容可能被截圖、轉貼、搜尋引擎或分散式系統保存。發布前要把長期可見性納入判斷。</p>
        </article>
      </div>
    </section>

    <section class="trace-story" id="trace" aria-labelledby="trace-title" data-trace-story>
      <header class="section-heading section-shell">
        <p class="eyebrow">TRACE ATLAS</p>
        <h2 id="trace-title">同一個帳號，會留下四種不同足跡</h2>
        <p>選擇你最常做的事。每條路徑都只揭露一部分，真正的風險通常來自它們被拼在一起。</p>
      </header>

      <div class="trace-layout section-shell">
        <div class="trace-chapters">
          {scenarios.map((scenario, index) => (
            <article
              class:list={['trace-chapter', { 'is-active': index === 0 }]}
              data-trace-chapter={scenario.id}
              aria-current={index === 0 ? 'step' : undefined}
            >
              <p class="trace-chapter__index">{scenario.index} / 04</p>
              <p class="trace-chapter__kicker">{scenario.kicker}</p>
              <h3>{scenario.title}</h3>
              <p class="trace-chapter__summary">{scenario.summary}</p>
              <div class="trace-chapter__lists">
                <div>
                  <h4>可能留下</h4>
                  <ul>{scenario.traces.map((trace) => <li>{trace}</li>)}</ul>
                </div>
                <div>
                  <h4>先做這些</h4>
                  <ul>{scenario.actions.map((action) => <li>{action}</li>)}</ul>
                </div>
              </div>
            </article>
          ))}
        </div>
        <div class="trace-visual-wrap" data-trace-pin>
          <FootprintMap context="story" />
          <div class="trace-readout" aria-hidden="true">
            <p>ACTIVE TRACE</p>
            <strong data-trace-readout>01 / 閱讀</strong>
          </div>
        </div>
      </div>
    </section>

    <section class="action-plan section-shell" id="plan" aria-labelledby="plan-title" data-action-plan>
      <header class="section-heading section-heading--split">
        <div>
          <p class="eyebrow">YOUR FIELD NOTES</p>
          <h2 id="plan-title">建立你的行動清單</h2>
        </div>
        <p>清單只在目前頁面運作，不會保存或傳送。你可以在裝置上複製或列印結果。完成幾項不代表「已安全」。</p>
      </header>

      <div class="scenario-picker" aria-labelledby="scenario-picker-title">
        <div>
          <p class="scenario-picker__label" id="scenario-picker-title">我會在 Matters</p>
          <p class="scenario-picker__hint">可複選。尚未選擇時顯示完整清單。</p>
        </div>
        <div class="scenario-picker__buttons" role="group" aria-label="選擇使用情境">
          {scenarios.map((scenario) => (
            <button class="scenario-button" type="button" data-scenario-button={scenario.id} aria-pressed="false">
              <span>{scenario.index}</span>{scenario.title}
            </button>
          ))}
        </div>
      </div>

      <div class="plan-status" aria-live="polite">
        <p data-plan-summary>目前顯示完整清單，共 {actionTasks.length} 項</p>
        <div class="plan-tools" aria-label="清單工具">
          <button type="button" class="plan-reset" data-plan-reset>清除選擇與勾選</button>
          <button type="button" class="ds-btn ds-btn--secondary ds-btn--medium" data-plan-copy>複製我的清單</button>
          <button type="button" class="ds-btn ds-btn--secondary ds-btn--medium" data-plan-print>列印</button>
        </div>
      </div>

      <div class="task-columns">
        {Object.entries(priorityLabels).map(([priority, label]) => (
          <section class={`task-column task-column--${priority}`} data-task-group={priority}>
            <header>
              <span>{label.index}</span>
              <div>
                <h3>{label.title}</h3>
                <p>{label.note}</p>
              </div>
            </header>
            <div class="task-list">
              {taskGroups[priority as keyof typeof taskGroups].map((task) => (
                <article
                  class="task-card"
                  data-task-card
                  data-task-id={task.id}
                  data-scenarios={task.scenarios.join(',')}
                >
                  <label class="task-card__toggle">
                    <input type="checkbox" data-task-checkbox />
                    <span class="task-card__check" aria-hidden="true"></span>
                    <span class="task-card__body">
                      <strong>{task.title}</strong>
                      <span>{task.detail}</span>
                    </span>
                  </label>
                  <small class="task-card__sources">
                    依據{' '}
                    {task.sourceIds.map((sourceId, sourceIndex) => {
                      const source = researchReferenceById.get(sourceId)
                      if (!source) return null
                      return (
                        <>
                          {sourceIndex > 0 && '、'}
                          <a href={source.href} target="_blank" rel="noopener noreferrer">{source.shortName}</a>
                        </>
                      )
                    })}
                  </small>
                </article>
              ))}
            </div>
          </section>
        ))}
      </div>
    </section>

    <section class="knowledge" id="knowledge" aria-labelledby="knowledge-title">
      <div class="section-shell">
        <header class="section-heading section-heading--light">
          <p class="eyebrow">SIX LAYERS</p>
          <h2 id="knowledge-title">一套做法，保護不了所有層次</h2>
          <p>從帳號到事件應變，逐層檢查。每個層次都包含技術、習慣與需要他人協助的部分。</p>
        </header>
        <div class="knowledge-grid">
          {knowledgeTopics.map((topic) => (
            <article class="knowledge-card" id={`topic-${topic.id}`}>
              <p class="knowledge-card__index">{topic.index}</p>
              <h3>{topic.title}</h3>
              <p>{topic.lead}</p>
              <ul>{topic.points.map((point) => <li>{point}</li>)}</ul>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="evidence section-shell" id="evidence" aria-labelledby="evidence-title" data-dashboard>
      <header class="section-heading section-heading--split">
        <div>
          <p class="eyebrow">EVIDENCE, NOT PROMISES</p>
          <h2 id="evidence-title">Matters 措施與證據</h2>
        </div>
        <p>狀態反映目前可查核的證據，不等同整個平台的安全評分。缺少證據時會明確保留，不以推測補上。</p>
      </header>

      <div class="dashboard-summary" aria-label="證據狀態總覽">
        <article>
          <p><span class="status-shape status-shape--verified"></span>已驗證</p>
          <strong>
            <span class="sr-only">{evidenceCounts.verified} 項</span>
            <span aria-hidden="true" data-count={evidenceCounts.verified}>{evidenceCounts.verified}</span>
          </strong>
          <span>項公開或可重現證據</span>
        </article>
        <article>
          <p><span class="status-shape status-shape--pending"></span>待補證據</p>
          <strong>
            <span class="sr-only">{evidenceCounts.pending} 項</span>
            <span aria-hidden="true" data-count={evidenceCounts.pending}>{evidenceCounts.pending}</span>
          </strong>
          <span>項需要產品團隊確認</span>
        </article>
        <article>
          <p><span class="status-shape status-shape--policy"></span>政策處理中</p>
          <strong>
            <span class="sr-only">{evidenceCounts.policy} 項</span>
            <span aria-hidden="true" data-count={evidenceCounts.policy}>{evidenceCounts.policy}</span>
          </strong>
          <span>項等待條款與治理更新</span>
        </article>
        <div class="dashboard-bar" aria-hidden="true">
          <span class:list={['dashboard-bar__verified', `dashboard-bar__size-${evidenceCounts.verified}`]}></span>
          <span class:list={['dashboard-bar__pending', `dashboard-bar__size-${evidenceCounts.pending}`]}></span>
          <span class:list={['dashboard-bar__policy', `dashboard-bar__size-${evidenceCounts.policy}`]}></span>
        </div>
      </div>

      <div class="evidence-list">
        {evidenceItems.map((item, index) => (
          <article class="evidence-card" data-evidence-card>
            <p class="evidence-card__index">{String(index + 1).padStart(2, '0')}</p>
            <div class="evidence-card__main">
              <div class="evidence-card__title">
                <h3>{item.title}</h3>
                <span class={`status-badge status-badge--${item.status}`}>
                  <i class={`status-shape status-shape--${item.status}`}></i>{item.statusLabel}
                </span>
              </div>
              <dl>
                <div><dt>證據</dt><dd>{item.evidence}</dd></div>
                <div><dt>限制</dt><dd>{item.limit}</dd></div>
                <div><dt>最後驗證</dt><dd>{item.verifiedAt}</dd></div>
                <div><dt>負責方</dt><dd>{item.owner}</dd></div>
              </dl>
            </div>
            {item.href ? (
              <a class="evidence-card__link" href={item.href} target="_blank" rel="noopener noreferrer" aria-label={`查看 ${item.title} 的外部證據`}>
                ↗
              </a>
            ) : (
              <span class="evidence-card__link evidence-card__link--disabled" aria-label="尚無公開證據連結">·</span>
            )}
          </article>
        ))}
      </div>
      <p class="evidence-note">
        完整維護規則與 repo 證據見 <a href="https://github.com/thematters/matters-safety-guide/blob/main/docs/evidence-matrix.md" target="_blank" rel="noopener noreferrer">evidence matrix ↗</a>
      </p>
    </section>

    <section class="incident section-shell" id="emergency" aria-labelledby="incident-title">
      <header class="section-heading">
        <p class="eyebrow">WHEN SOMETHING HAPPENS</p>
        <h2 id="incident-title">急迫事件先保護人，再處理帳號</h2>
        <p>若你面臨立即人身危險，先離開危險環境並聯絡可信任的人。數位排查不應增加現實風險。</p>
      </header>
      <div class="incident-list">
        <details id="account-compromise" open>
          <summary><span>01</span>帳號疑似遭入侵</summary>
          <div>
            <ol>
              <li>從可信任的乾淨裝置開啟註冊信箱與 Matters。</li>
              <li>先改信箱密碼，再處理平台密碼與所有既有工作階段。</li>
              <li>保存異常登入通知、時間與變更紀錄，不要公開敏感截圖。</li>
              <li>若無法確認入侵範圍，停止在原裝置處理並尋求協助。</li>
            </ol>
          </div>
        </details>
        <details id="harassment">
          <summary><span>02</span>持續騷擾或威脅</summary>
          <div>
            <ol>
              <li>保存原始網址、時間與必要截圖，避免反覆轉貼造成擴散。</li>
              <li>檢查個人頁、舊文章與其他平台是否能拼出住處、工作或關係人。</li>
              <li>告知可信任的人並建立固定報平安方式。</li>
              <li>威脅涉及現實位置或暴力時，尋求在地法律與安全支援。</li>
            </ol>
          </div>
        </details>
        <details id="device-monitoring">
          <summary><span>03</span>裝置疑似被監控</summary>
          <div>
            <ol>
              <li>不要立刻在疑似受監控的裝置搜尋移除方式或討論事件。</li>
              <li>改用可信任的其他裝置與網路聯絡專業支援。</li>
              <li>不要自行重置或刪除資料，以免破壞鑑識證據或引發對手反應。</li>
              <li>由專業人員協助評估帳號、裝置與人身風險的處置順序。</li>
            </ol>
          </div>
        </details>
      </div>
      <div class="incident-help">
        <div>
          <p>帳號與平台問題可先聯絡 Matters 產品支援。高風險個案可尋求外部數位安全協助。</p>
          <a href="mailto:ask@matters.town">ask@matters.town</a>
        </div>
        <a class="ds-btn ds-btn--primary ds-btn--large" href="https://www.accessnow.org/help/" target="_blank" rel="noopener noreferrer">Access Now 24/7 數位安全熱線 ↗</a>
      </div>
    </section>

    <section class="sources section-shell" id="sources" aria-labelledby="sources-title">
      <header class="section-heading section-heading--split">
        <div>
          <p class="eyebrow">RESEARCH SOURCES</p>
          <h2 id="sources-title">研究來源</h2>
        </div>
        <p>優先採用數位安全組織與公共機構的第一方指南。連結內容可能更新，本站每次發布都應重新核對。</p>
      </header>
      <div class="source-list">
        {sources.map((source, index) => (
          <a href={source.href} target="_blank" rel="noopener noreferrer">
            <span>{String(index + 1).padStart(2, '0')}</span>
            <strong>{source.name}</strong>
            <p>{source.scope}</p>
            <i aria-hidden="true">↗</i>
          </a>
        ))}
      </div>
    </section>
  </main>

  <footer class="site-footer" id="about">
    <div>
      <p class="eyebrow">MATTERS FIELD GUIDE · 001</p>
      <h2>保護從誠實說明限制開始</h2>
    </div>
    <div class="footer-meta">
      <p>版本 1.1<br />最後驗證 2026-07-14<br />維護者 Matters</p>
      <p>本站程式不使用應用層分析、不主動設定 cookie，也不保存你的清單。Cloudflare 仍可能為安全與防濫用處理請求中繼資料，並在安全挑戰時設定必要 cookie。</p>
      <nav aria-label="頁尾連結">
        <a href="https://matters.town/tos" target="_blank" rel="noopener noreferrer">服務條款 ↗</a>
        <a href="https://github.com/thematters/matters-safety-guide" target="_blank" rel="noopener noreferrer">原始碼 ↗</a>
        <a href="/.well-known/security.txt">安全聯絡</a>
      </nav>
    </div>
  </footer>

  <div class="sr-only" aria-live="polite" data-live-region></div>

  <script>
    import '../scripts/interactions'
    import '../scripts/animations'
  </script>
</BaseLayout>
